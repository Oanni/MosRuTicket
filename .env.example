TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Через запятую — ID чатов, которые получают уведомления без /subscribe
TELEGRAM_ADMIN_IDS=
# Интервал проверки в секундах (по умолчанию 60)
CHECK_INTERVAL=60
# Окно бронирования: сколько дней вперёд открыта запись (как на сайте)
BOOKING_WINDOW_DAYS=3
# Базовый URL API
API_BASE_URL=https://api.outdoor.sport.mos.ru
